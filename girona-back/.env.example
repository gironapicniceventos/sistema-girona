# Local Postgres via Unix socket.
# This form does NOT include host/port; psycopg2 uses the local socket.
DATABASE_URL=postgresql://postgres@/girona_dev

# If your Postgres runs on TCP (Docker/remote), use a full URL, e.g.:
# DATABASE_URL=postgresql://user:password@localhost:5432/girona_dev

# Set to 0 to start the API without touching the DB on startup.
AUTO_CREATE_TABLES=1

# Factus (sandbox by default)
FACTUS_ENABLED=1
FACTUS_ENVIRONMENT=sandbox
FACTUS_API_BASE_URL=https://api-sandbox.factus.com.co
FACTUS_TOKEN_URL=https://api-sandbox.factus.com.co/oauth/token
FACTUS_CLIENT_ID=
FACTUS_CLIENT_SECRET=
FACTUS_USERNAME=
FACTUS_PASSWORD=

# Billing defaults
FACTUS_NUMBERING_RANGE_ID=
# Opcional: si hay varios rangos activos, elige por prefijo (ej. NEF). Si no, se usa el primero activo.
FACTUS_NUMBERING_RANGE_PREFIX=
FACTUS_PAYMENT_FORM_CODE=1
FACTUS_PAYMENT_METHOD_CODE=10
FACTUS_OPERATION_TYPE=10
FACTUS_DEFAULT_CUSTOMER_EMAIL=
# Si el cliente no trae email y no hay FACTUS_DEFAULT_CUSTOMER_EMAIL, Factus recibe este valor y no se envia correo (send_email=false).
FACTUS_PLACEHOLDER_CUSTOMER_EMAIL=no-informa@example.com
FACTUS_DEFAULT_CUSTOMER_ADDRESS="No informado"
FACTUS_DEFAULT_MUNICIPALITY_ID=
FACTUS_IDENTIFICATION_DOCUMENT_ID=3
FACTUS_LEGAL_ORGANIZATION_ID=2
FACTUS_CUSTOMER_TRIBUTE_ID=21
FACTUS_ITEM_STANDARD_CODE_ID=1
FACTUS_ITEM_UNIT_MEASURE_ID=70
FACTUS_ITEM_TRIBUTE_ID=1
FACTUS_ESTABLISHMENT_NAME=
FACTUS_ESTABLISHMENT_ADDRESS=
FACTUS_ESTABLISHMENT_PHONE=
FACTUS_ESTABLISHMENT_EMAIL=
FACTUS_ESTABLISHMENT_MUNICIPALITY_ID=

# Notas crédito (anular factura validada — POST /v1/credit-notes/validate)
# Rango de numeración para NC; si no se define, se usa FACTUS_NUMBERING_RANGE_ID.
FACTUS_CREDIT_NOTE_NUMBERING_RANGE_ID=
# Código concepto corrección Factus (2 = anulación de factura de venta).
FACTUS_CREDIT_NOTE_CORRECTION_CODE=2
# Personalización que referencia factura (20 en documentación típica Factus).
FACTUS_CREDIT_NOTE_CUSTOMIZATION_ID=20

# Usuarios / roles (seed en arranque)
# SEED_STAFF_USERS=1 crea o actualiza nombre y rol de la plantilla en app/seed_staff.py (contraseña solo en usuario nuevo).
# SEED_RESET_STAFF_PASSWORDS=1 fuerza reaplicar contraseñas del seed (útil tras rotación en pruebas).
SEED_STAFF_USERS=1
# SEED_RESET_STAFF_PASSWORDS=0

# Registro público /auth/signup (frontend oculta Registrarse; mantener en 0 en producción).
# ALLOW_PUBLIC_SIGNUP=1

# Automatic kitchen/bar ticket printing on Windows
POS_AUTO_PRINT_COMANDA=0
# Can be printer name, queue name or IP hint (example: 192.168.1.9)
POS_COMANDA_PRINTER=M2020
POS_COMANDA_SPLIT_BY_ZONE=1
POS_COMANDA_COPIES=1

# Google Calendar (reservas)
# Set GOOGLE_CALENDAR_ENABLED=1 to enforce sync on create/update.
GOOGLE_CALENDAR_ENABLED=1
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=America/Bogota
GOOGLE_CALENDAR_NOTIFY_EMAIL=
GOOGLE_CALENDAR_EVENT_DURATION_MINUTES=120
# Use one of these two options for service account credentials:
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_FILE=

# --- Railway / hosting tipo PaaS (Docker) ---
# Railway inyecta DATABASE_URL desde Postgres y PORT para el proceso web.
# Evita esperar TCP a host.docker.internal (compose local):
GIRONA_DB_SKIP_WAIT=1
