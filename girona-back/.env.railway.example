# Plantilla de variables para el servicio "girona-back" en Railway.
# Estas variables NO se cargan localmente; se copian al panel:
#   Service -> Variables -> Raw editor (pegar el bloque)
#
# Las que comienzan con ${{ ... }} son "reference variables": Railway las
# resuelve apuntando al servicio Postgres del MISMO proyecto. Cambia
# "Postgres" por el nombre exacto que tenga tu plugin/servicio de Postgres.

# --- Base de datos ---
# Conexion privada (interna de Railway). No requiere SSL.
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Saltar el "wait TCP" del docker-entrypoint.sh (en compose local espera la BD).
GIRONA_DB_SKIP_WAIT=1

# --- Bootstrap del schema ---
AUTO_CREATE_TABLES=1
AUTO_MIGRATE_SCHEMA=1

# --- Factus (produccion). Si no usas facturacion electronica deja FACTUS_ENABLED=0 ---
FACTUS_ENABLED=1
FACTUS_ENVIRONMENT=production
FACTUS_API_BASE_URL=https://api.factus.com.co
FACTUS_TOKEN_URL=https://api.factus.com.co/oauth/token
FACTUS_CLIENT_ID=
FACTUS_CLIENT_SECRET=
FACTUS_USERNAME=
FACTUS_PASSWORD=

# Rango de numeracion (id numerico del rango "Factura de venta" en Factus).
FACTUS_NUMBERING_RANGE_ID=
FACTUS_NUMBERING_RANGE_PREFIX=
FACTUS_PAYMENT_FORM_CODE=1
FACTUS_PAYMENT_METHOD_CODE=10
FACTUS_OPERATION_TYPE=10

# Cliente / municipio por defecto para POS sin datos del cliente.
FACTUS_DEFAULT_CUSTOMER_EMAIL=
FACTUS_PLACEHOLDER_CUSTOMER_EMAIL=no-informa@example.com
FACTUS_DEFAULT_CUSTOMER_ADDRESS=No informado
FACTUS_DEFAULT_MUNICIPALITY_ID=

FACTUS_IDENTIFICATION_DOCUMENT_ID=3
FACTUS_LEGAL_ORGANIZATION_ID=2
FACTUS_CUSTOMER_TRIBUTE_ID=21
FACTUS_ITEM_STANDARD_CODE_ID=1
FACTUS_ITEM_UNIT_MEASURE_ID=70
# INC (código DIAN 04): tribute_id habitual en Factus = 2; IVA habitual = 1.
FACTUS_ITEM_TRIBUTE_ID=2

FACTUS_ESTABLISHMENT_NAME=
FACTUS_ESTABLISHMENT_ADDRESS=
FACTUS_ESTABLISHMENT_PHONE=
FACTUS_ESTABLISHMENT_EMAIL=
FACTUS_ESTABLISHMENT_MUNICIPALITY_ID=

# --- Google Calendar (reservas). Si no se usa, deja GOOGLE_CALENDAR_ENABLED=0 ---
GOOGLE_CALENDAR_ENABLED=0
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=America/Bogota
GOOGLE_CALENDAR_NOTIFY_EMAIL=
GOOGLE_CALENDAR_EVENT_DURATION_MINUTES=120
# Pega el JSON completo de la service account aqui (en una sola linea o multilinea).
GOOGLE_SERVICE_ACCOUNT_JSON=
