# URL del backend (FastAPI) accesible públicamente
BACKEND_URL=https://tu-backend.ejemplo.com

# Opcionales (si tu backend usa rutas no estándar)
# BACKEND_LOGIN_PATHS=/auth/login,/auth/jwt/login,/token
# BACKEND_SIGNUP_PATH=/auth/signup

# Opcionales para autocompletar login demo en UI
# NEXT_PUBLIC_DEMO_USER_MAIL=
# NEXT_PUBLIC_DEMO_USER_PASS=

# Correos separados por coma: historial siempre sin columnas/ocultamiento local por cajero (dueños tipo caja)
# NEXT_PUBLIC_SALES_HISTORY_OWNER_EMAILS=jefe@girona.com,laura@girona.com

# --- Térmica prefactura (ESC/POS, ej. Daruma DIG-E200I en LAN :9100) ---
# URL codificada en QR al pie del ticket. Marcadores: {orderId} o {id}
# NEXT_PUBLIC_THERMAL_PREFACTURA_QR_URL=https://tu-dominio.com/pos?pedido={orderId}
#
# Vercel/LAN: IP del PC donde corre el puente (no 127.0.0.1 si el POS se abre desde otra tablet/PC).
# En la caja: node scripts/thermal-print-bridge.mjs  (escucha 0.0.0.0:3040; al arrancar lista las URLs LAN)
# Vercel (HTTPS): https://192.168.0.228:3041  — abrir /health y aceptar certificado autofirmado
# NEXT_PUBLIC_THERMAL_BRIDGE_URL=https://192.168.1.100:3041
# En el POS, IP impresora = IP de la térmica en LAN, puerto 9100 (no :631 CUPS).
