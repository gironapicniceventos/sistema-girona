# Copiar a .env y completar credenciales (no commitear .env).
# Documentación: https://developers.factus.com.co/v1/notas-credito/crear-y-validar/

FACTUS_ENVIRONMENT=sandbox
# FACTUS_API_BASE_URL=https://api-sandbox.factus.com.co
# FACTUS_TOKEN_URL=https://api-sandbox.factus.com.co/oauth/token
FACTUS_CLIENT_ID=
FACTUS_CLIENT_SECRET=
FACTUS_USERNAME=
FACTUS_PASSWORD=

# Rango para nota crédito (o deja vacío si Factus tiene un solo rango activo).
FACTUS_CREDIT_NOTE_NUMBERING_RANGE_ID=
FACTUS_NUMBERING_RANGE_ID=

FACTUS_CREDIT_NOTE_CORRECTION_CODE=2
FACTUS_CREDIT_NOTE_CUSTOMIZATION_ID=20
FACTUS_PAYMENT_METHOD_CODE=10

# Datos de ítems (mismos defaults que en girona-back si no defines lo demás).
FACTUS_ITEM_STANDARD_CODE_ID=1
FACTUS_ITEM_UNIT_MEASURE_ID=70
FACTUS_ITEM_TRIBUTE_ID=2

# --- Conexión a Postgres (solo con --from-invoice-db) ---
# Por defecto: host.docker.internal + POSTGRES_HOST_PORT del .env raíz.
# LAB_DB_HOST=host.docker.internal

# --- Laboratorio: factura a anular / ajustar ---
LAB_BILL_ID=
# Opcional: si no se define, se genera un código con timestamp.
LAB_REFERENCE_CODE=
LAB_SEND_EMAIL=0
# LAB_OBSERVATION=

# Cuerpo completo (opcional): ruta a JSON con el body del POST.
# Si está definido, se ignora el armado desde env + --items.
# LAB_PAYLOAD_JSON=/workspace/examples/payload.full.example.json
